generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum ContractType {
  CONDITION_VENTE
  LOCATION
}

enum CautionMovementType {
  DEPOT_INITIAL
  RECHARGE_VOLONTAIRE
  DEDUCTION_PANNE
  DEDUCTION_SANCTION
  RETRAIT
}

enum PaymentMode {
  ESPECES
  MOBILE_MONEY
  VIREMENT
  AUTRE
  PORTEFEUILLE
}

enum AccountingType {
  ENTREE
  SORTIE
}

enum WalletMovementType {
  DEPOT
  RETRAIT
}

// Structures du groupe Empire, gérées depuis la cellule Comptabilité.
enum BusinessUnit {
  EMPIRE_ASSURANCE
  AUTO_ECOLE_EMPIRE
  EMPIRE_LANGUAGE_ACADEMY
  EMPIRE_TRAVEL
  EMPIRE_DRIVE
  EMPIRE_SECURE
}

enum StockMovementType {
  APPRO  // réapprovisionnement (entrée de stock)
  VENTE  // vente (sortie de stock, génère une recette)
  AJUSTEMENT // correction d'inventaire
}

// Motif d'immobilisation d'un véhicule au garage.
enum GarageReasonType {
  PANNE
  REPARATION
  ENTRETIEN
  ACCIDENT
  AUTRE
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  fullName     String
  role         Role
  active       Boolean  @default(true)
  // Surcharge de capacités par utilisateur, définie par l'administrateur.
  // Objet { capKey: boolean } ; absence de clé = valeur par défaut du rôle.
  capabilities Json?
  avatarUrl    String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignments      Assignment[]
  paymentsEntered  Payment[]            @relation("PaymentEnteredBy")
  cautionEntered   CautionMovement[]    @relation("CautionEnteredBy")
  weeklyEntered    WeeklyTracking[]     @relation("WeeklyEnteredBy")
  commentsAuthored Comment[]            @relation("CommentAuthor")
  auditLogs        AuditLog[]
  pendingDriversEntered PendingDriver[] @relation("PendingDriverEnteredBy")
  chatMessages     ChatMessage[]        @relation("ChatMessageAuthor")
  ownerCommissions     OwnerCommission[]     @relation("OwnerCommissionEnteredBy")
  ownerPrefinancement  OwnerPrefinancement[] @relation("OwnerPrefinancementEnteredBy")
  accountingEntered    AccountingEntry[]     @relation("AccountingEnteredBy")
  pendingDriverComments PendingDriverComment[] @relation("PendingDriverCommentAuthor")
  ownerComments        OwnerComment[]        @relation("OwnerCommentAuthor")
  pendingOwnersEntered  PendingOwner[]        @relation("PendingOwnerEnteredBy")
  pendingOwnerComments  PendingOwnerComment[] @relation("PendingOwnerCommentAuthor")
  walletMovementsEntered WalletMovement[]     @relation("WalletMovementEnteredBy")
  productsCreated       Product[]             @relation("ProductCreatedBy")
  stockMovementsEntered StockMovement[]       @relation("StockMovementEnteredBy")
  structureAssignments  StructureAssignment[]
  garageEntriesEntered  GarageEntry[]         @relation("GarageEntryEnteredBy")

  @@map("users")
}

// Chauffeurs en attente d'affectation de véhicule : ont déjà versé une caution/avance
// mais n'ont pas encore de véhicule (donc pas encore dans la table Driver).
model PendingDriver {
  id           String       @id @default(cuid())
  fullName     String
  phone        String
  location     String?
  licenseNumber String?
  contractType ContractType
  cautionPaid  Decimal      @default(0) @db.Decimal(14, 2)
  comment      String?
  enteredById  String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  enteredBy User @relation("PendingDriverEnteredBy", fields: [enteredById], references: [id])
  comments  PendingDriverComment[]

  @@map("pending_drivers")
}

// Fil de commentaires horodatés sur un prospect en attente (indépendant du champ "comment" ponctuel).
model PendingDriverComment {
  id              String   @id @default(cuid())
  pendingDriverId String
  text            String
  authorId        String
  createdAt       DateTime @default(now())

  pendingDriver PendingDriver @relation(fields: [pendingDriverId], references: [id], onDelete: Cascade)
  author        User          @relation("PendingDriverCommentAuthor", fields: [authorId], references: [id])

  @@map("pending_driver_comments")
}

// Propriétaires prospects : pas encore intégrés à la table Owner (en cours de discussion/onboarding).
model PendingOwner {
  id          String   @id @default(cuid())
  fullName    String
  phone       String
  location    String?
  comment     String?
  enteredById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  enteredBy User @relation("PendingOwnerEnteredBy", fields: [enteredById], references: [id])
  comments  PendingOwnerComment[]

  @@map("pending_owners")
}

// Fil de commentaires horodatés sur un propriétaire en attente.
model PendingOwnerComment {
  id             String   @id @default(cuid())
  pendingOwnerId String
  text           String
  authorId       String
  createdAt      DateTime @default(now())

  pendingOwner PendingOwner @relation(fields: [pendingOwnerId], references: [id], onDelete: Cascade)
  author       User         @relation("PendingOwnerCommentAuthor", fields: [authorId], references: [id])

  @@map("pending_owner_comments")
}

model Owner {
  id          String   @id @default(cuid())
  fullName    String
  phone       String
  location    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  drivers         Driver[]
  commissions     OwnerCommission[]
  prefinancements OwnerPrefinancement[]
  comments        OwnerComment[]

  @@map("owners")
}

// Fil de commentaires horodatés sur un propriétaire.
model OwnerComment {
  id        String   @id @default(cuid())
  ownerId   String
  text      String
  authorId  String
  createdAt DateTime @default(now())

  owner  Owner @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  author User  @relation("OwnerCommentAuthor", fields: [authorId], references: [id])

  @@map("owner_comments")
}

model OwnerCommission {
  id          String   @id @default(cuid())
  ownerId     String
  weekStart   DateTime // lundi de la semaine
  amount      Decimal  @db.Decimal(14, 2)
  note        String?
  enteredById String
  createdAt   DateTime @default(now())

  owner     Owner @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  enteredBy User  @relation("OwnerCommissionEnteredBy", fields: [enteredById], references: [id])

  @@unique([ownerId, weekStart])
  @@map("owner_commissions")
}

model OwnerPrefinancement {
  id          String   @id @default(cuid())
  ownerId     String
  driverId    String?  // véhicule concerné (optionnel)
  weekStart   DateTime // lundi de la semaine
  amount      Decimal  @db.Decimal(14, 2)
  note        String?
  enteredById String
  createdAt   DateTime @default(now())

  owner     Owner   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  driver    Driver? @relation("DriverPrefinancements", fields: [driverId], references: [id], onDelete: SetNull)
  enteredBy User    @relation("OwnerPrefinancementEnteredBy", fields: [enteredById], references: [id])

  @@map("owner_prefinancements")
}

model Driver {
  id               String       @id @default(cuid())
  code             String       @unique // CH-001 / LOC-001
  fullName         String
  phone            String
  location         String?
  licenseNumber    String?
  contractType     ContractType

  ownerId          String?
  owner            Owner?       @relation(fields: [ownerId], references: [id])

  ownerName        String
  ownerPhone       String
  ownerLocation    String?

  guarantorName    String?
  guarantorPhone   String?

  vehicleBrand     String
  vehicleModel     String
  vehiclePlate     String
  vehicleColor     String?
  vehicleInService DateTime?

  // Condition-Vente specifics
  totalPriceFixed  Decimal?     @db.Decimal(14, 2)

  // Location specifics
  cautionReference Decimal?     @db.Decimal(14, 2)
  cautionMinThreshold Decimal?  @db.Decimal(14, 2)

  hourlyPenaltyRate Decimal     @default(0) @db.Decimal(14, 2)
  weeklyHourTarget  Int         @default(55)

  active           Boolean      @default(true)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assignments      Assignment[]
  payments         Payment[]
  cautionMovements CautionMovement[]
  weeklyTrackings  WeeklyTracking[]
  comments         Comment[]
  prefinancements  OwnerPrefinancement[] @relation("DriverPrefinancements")
  walletMovements  WalletMovement[]
  garageEntries    GarageEntry[]

  @@map("drivers")
}

// Immobilisation d'un véhicule au garage (panne, réparation, entretien...).
// resolvedAt null = toujours inactif ; renseigné = remis en service.
model GarageEntry {
  id          String           @id @default(cuid())
  driverId    String
  reasonType  GarageReasonType
  reason      String           // motif détaillé de la panne/réparation
  enteredAt   DateTime         // date de mise hors service
  resolvedAt  DateTime?        // date de remise en service (null = toujours au garage)
  note        String?
  enteredById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  enteredBy User   @relation("GarageEntryEnteredBy", fields: [enteredById], references: [id])

  @@index([driverId])
  @@index([resolvedAt])
  @@map("garage_entries")
}

// Portefeuille des chauffeurs Condition-Vente : réserve de trésorerie courante où le
// surplus/avance d'un versement peut être gardé, puis déduit manuellement lors de
// l'intégration d'un versement ultérieur. Indépendant de l'avance/caution déduite
// du reste à verser pour l'acquisition du véhicule.
model WalletMovement {
  id            String             @id @default(cuid())
  driverId      String
  date          DateTime
  type          WalletMovementType
  amount        Decimal            @db.Decimal(14, 2) // signé : positif = dépôt, négatif = retrait
  reason        String?
  resultBalance Decimal            @db.Decimal(14, 2)
  enteredById   String
  createdAt     DateTime           @default(now())

  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  enteredBy User   @relation("WalletMovementEnteredBy", fields: [enteredById], references: [id])

  @@map("wallet_movements")
}

model Assignment {
  id         String   @id @default(cuid())
  employeeId String
  driverId   String
  createdAt  DateTime @default(now())

  employee User   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  driver   Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([employeeId, driverId])
  @@map("assignments")
}

// Versements (Condition-Vente) et Loyers (Location) — meme table, distingue par driver.contractType
model Payment {
  id            String      @id @default(cuid())
  driverId      String
  date          DateTime
  amount        Decimal     @db.Decimal(14, 2)
  paymentMode   PaymentMode @default(ESPECES)
  comment       String?
  isUnusualDay  Boolean     @default(false) // mardi/dimanche
  // Jour à 0 FCFA car le véhicule n'a pas été exploité (panne, entretien, indisponibilité...).
  isInactive       Boolean  @default(false)
  inactivityReason String?
  enteredById   String
  createdAt     DateTime    @default(now())

  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  enteredBy User   @relation("PaymentEnteredBy", fields: [enteredById], references: [id])

  @@map("payments")
}

model CautionMovement {
  id            String              @id @default(cuid())
  driverId      String
  date          DateTime
  type          CautionMovementType
  amount        Decimal             @db.Decimal(14, 2) // peut etre negatif (deduction) ou positif
  reason        String?
  resultBalance Decimal             @db.Decimal(14, 2) // solde apres ce mouvement
  enteredById   String
  createdAt     DateTime            @default(now())

  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  enteredBy User   @relation("CautionEnteredBy", fields: [enteredById], references: [id])

  @@map("caution_movements")
}

model WeeklyTracking {
  id               String   @id @default(cuid())
  driverId         String
  weekStartDate    DateTime // lundi de la semaine concernee
  hoursWorked      Decimal  @db.Decimal(6, 2)
  ridesCompleted   Int
  hourTarget       Int      // copie de driver.weeklyHourTarget au moment de la saisie
  penaltyRateUsed  Decimal  @db.Decimal(14, 2) // copie de driver.hourlyPenaltyRate
  computedPenalty  Decimal  @db.Decimal(14, 2) // (hourTarget - hoursWorked) * penaltyRateUsed si positif, sinon 0
  penaltyApplied   Boolean  @default(false)
  penaltyAppliedAt DateTime?
  enteredById      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  enteredBy User   @relation("WeeklyEnteredBy", fields: [enteredById], references: [id])

  @@unique([driverId, weekStartDate])
  @@map("weekly_trackings")
}

model Comment {
  id        String   @id @default(cuid())
  driverId  String
  date      DateTime @default(now())
  text      String
  authorId  String
  createdAt DateTime @default(now())

  driver Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)
  author User   @relation("CommentAuthor", fields: [authorId], references: [id])

  @@map("comments")
}

model ChatMessage {
  id        String   @id @default(cuid())
  content   String   @db.Text
  authorId  String
  author    User     @relation("ChatMessageAuthor", fields: [authorId], references: [id])
  createdAt DateTime @default(now())

  @@map("chat_messages")
}

// Comptabilité Empire : flux de trésorerie (entrées / sorties) saisi manuellement.
model AccountingEntry {
  id           String         @id @default(cuid())
  date         DateTime
  type         AccountingType
  category     String         // ex: "Recette flotte", "Salaire", "Carburant", "Réparation"...
  label        String         // libellé de l'opération
  amount       Decimal        @db.Decimal(14, 2) // toujours positif ; le signe vient du type
  paymentMode  PaymentMode    @default(ESPECES)
  note         String?
  // Rattachement optionnel à une structure Empire Group (null = écriture générale Empire Drive).
  businessUnit BusinessUnit?
  enteredById  String
  createdAt    DateTime       @default(now())

  enteredBy      User            @relation("AccountingEnteredBy", fields: [enteredById], references: [id])
  stockMovement  StockMovement?

  @@index([date])
  @@index([type])
  @@index([businessUnit])
  @@map("accounting_entries")
}

// Catalogue des produits en stock d'une structure (ex: Attestation, Manuel, Kit GPS).
model Product {
  id               String       @id @default(cuid())
  businessUnit     BusinessUnit
  name             String
  unitPrice        Decimal      @db.Decimal(14, 2)
  quantityInStock  Int          @default(0)
  active           Boolean      @default(true)
  createdById      String
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  createdBy       User             @relation("ProductCreatedBy", fields: [createdById], references: [id])
  stockMovements  StockMovement[]

  @@index([businessUnit])
  @@map("products")
}

// Mouvement de stock (vente / réappro / ajustement), avec lien optionnel vers
// l'écriture comptable générée automatiquement (recette de vente, coût d'achat).
model StockMovement {
  id                String            @id @default(cuid())
  productId         String
  type              StockMovementType
  quantity          Int
  unitPrice         Decimal           @db.Decimal(14, 2)
  totalAmount        Decimal           @db.Decimal(14, 2)
  resultStock       Int
  date              DateTime
  note              String?
  enteredById       String
  createdAt         DateTime          @default(now())
  accountingEntryId String?           @unique

  product         Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  enteredBy       User             @relation("StockMovementEnteredBy", fields: [enteredById], references: [id])
  accountingEntry AccountingEntry? @relation(fields: [accountingEntryId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@map("stock_movements")
}

// Affectation d'une structure à un gestionnaire : il peut saisir des opérations pour
// cette structure, modifiables/supprimables par lui pendant 5h (au-delà, ADMIN uniquement).
model StructureAssignment {
  id           String       @id @default(cuid())
  userId       String
  businessUnit BusinessUnit
  createdAt    DateTime     @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, businessUnit])
  @@map("structure_assignments")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // e.g. "CREATE_PAYMENT", "UPDATE_DRIVER", "APPLY_PENALTY"
  entity    String   // e.g. "Driver", "Payment"
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
